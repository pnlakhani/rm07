# RM07 — example environment surface. Real values live in Doppler (Hard rule: never commit secrets).
# Copy to .env for local dev and fill from Doppler `doppler run`.

# --- Core ---
NODE_ENV=development

# --- Supabase (ap-south-1) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rm07
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- API (NestJS, Railway) ---
API_PORT=8080
API_CORS_ORIGINS=http://localhost:3000
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Base64 of a 32-byte AES-256 key for the broker-credential vault. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leave blank in local dev (an ephemeral key is used). REQUIRED in production.
VAULT_ROOT_KEY=
# Access-JWT signing secret + OTP pepper (>=16 chars). Ephemeral in dev; REQUIRED in production.
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
OTP_PEPPER=

# --- Web (Next.js, Vercel) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI orchestrator (FastAPI, Railway) ---
AI_SVC_PORT=8090
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Redis (Upstash, ap-south-1) ---
REDIS_URL=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Market-data fan-out (Fargate) ---
MD_SVC_PORT=8100
