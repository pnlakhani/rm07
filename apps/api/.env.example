# RM07 API — local environment template.
# Copy this file to `.env` (in apps/api/) and fill in the values. `.env` is gitignored.
# The API auto-loads apps/api/.env on startup (zero-dependency loader in config/env.ts).
# In production these are injected by Doppler instead.
#
# Lines starting with # are ignored. Do not put inline comments after a value.

# --- Database: Supabase Session pooler connection string -------------------
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# --- Stable secrets: generate ONCE and keep constant -----------------------
# Changing these invalidates already-sealed data (TOTP secrets, broker credentials).
# VAULT_ROOT_KEY must be base64-encoded 32 bytes:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VAULT_ROOT_KEY=
JWT_ACCESS_SECRET=
OTP_PEPPER=

# --- Email (Resend). If RESEND_API_KEY is empty, OTP codes print to the console. ---
RESEND_API_KEY=
EMAIL_FROM=RM07 <no-reply@rm07.local>

# --- Razorpay (subscriptions). Leave empty until wiring real billing. ------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_MAP={"basic":"plan_xxx","pro":"plan_yyy"}
